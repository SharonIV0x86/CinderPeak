#-------------------------------------------------
# Project Information
#-------------------------------------------------
PROJECT_NAME           = "CinderPeak"
PROJECT_BRIEF          = "Modern C++ graph library"
PROJECT_NUMBER         = "dev"

OUTPUT_DIRECTORY       = docs/api
CREATE_SUBDIRS         = NO

#-------------------------------------------------
# Build Configuration
#-------------------------------------------------
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_XML           = YES

RECURSIVE              = YES
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES

#-------------------------------------------------
# Input
#-------------------------------------------------
INPUT                  = src README.md
FILE_PATTERNS          = *.hpp *.h *.md

USE_MDFILE_AS_MAINPAGE = README.md

#-------------------------------------------------
# C++ Parsing
#-------------------------------------------------
OPTIMIZE_OUTPUT_FOR_C  = NO
BUILTIN_STL_SUPPORT    = YES
CPP_CLI_SUPPORT        = NO

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO

#-------------------------------------------------
# Warnings
#-------------------------------------------------
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES

#-------------------------------------------------
# Source Browser
#-------------------------------------------------
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO

#-------------------------------------------------
# Graphs & Diagrams
#-------------------------------------------------
HAVE_DOT               = YES
CLASS_DIAGRAMS         = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO

DOT_IMAGE_FORMAT       = svg

#-------------------------------------------------
# Appearance
#-------------------------------------------------
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = YES

#-------------------------------------------------
# Aliases
#-------------------------------------------------
ALIASES += complexity="\\par Complexity:"
ALIASES += threadsafety="\\par Thread Safety:"
ALIASES += noteheader="\\par Notes:"